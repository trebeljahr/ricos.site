    "generateBacklinks": "tsx src/scripts/generateBacklinks.ts",
    "extractNowHistory": "tsx src/scripts/extractNowHistory.ts",
    "postbuild": "npm run generateSitemap && npm run generateRSS && npm run generateSearchIndex && npm run generateBacklinks",
    "postinstall": "patch-package",
    "start": "next start",
    "typecheck": "tsc",
    "tweet": "tsx src/scripts/tweet.ts",
    "renameFiles": "tsx src/scripts/renameFiles.ts",
